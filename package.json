{
  "name": "dashboard-flyin",
  "version": "1.0.0",
  "description": "High-end 3D dashboard fly-in Remotion component",
  "scripts": {
    "dev": "concurrently -n web,server -c cyan,magenta \"vite\" \"tsx watch server/index.ts\"",
    "start": "npx remotion studio",
    "build": "npx remotion render DashboardFlyIn out/video.mp4",
    "upgrade": "npx remotion upgrade",
    "web:dev": "vite",
    "web:build": "vite build",
    "server": "tsx watch server/index.ts",
    "build:prod": "vite build && tsc -p tsconfig.server.json",
    "serve:prod": "node dist/server/server/index.js"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.288",
    "@remotion/player": "^4.0.288",
    "@remotion/renderer": "4.0.288",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "remotion": "4.0.288",
    "zod": "^3.22.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@remotion/eslint-config": "4.0.288",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "@types/react": "18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  }
}
